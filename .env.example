# Supabase — copy this file to .env.local and fill in your values
# Find these in: Supabase Dashboard → Project Settings → API

# The anon/public key — get from Supabase Dashboard → Project Settings → API → anon public
# It starts with eyJ... NOT sb_publishable_
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# App URL (used for OAuth redirect + email confirmation links)
# Local: http://localhost:3004
# Production: https://tabeza-crew.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3004
